generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameState {
  CREATED
  STARTED
  AT_CHECKPOINT
  PUZZLE_ACTIVE
  PUZZLE_SOLVED
  WAITING_FOR_VALIDATION
  COMPLETED
  FAILED
}

enum PuzzleType {
  TEXT
  PHOTO
}

enum Role {
  PLAYER
  ADMIN
}

model User {
  id                 String        @id @default(uuid())
  email              String        @unique
  password           String
  hashedRefreshToken String?
  name               String?
  role               Role          @default(PLAYER)
  groups             GroupMember[]
  ledGroups          Group[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Group {
  id        String        @id @default(uuid())
  name      String
  leader    User          @relation(fields: [leaderId], references: [id])
  leaderId  String
  members   GroupMember[]
  sessions  GameSession[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model GroupMember {
  id       String   @id @default(uuid())
  group    Group    @relation(fields: [groupId], references: [id])
  groupId  String
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  role     String   @default("player")
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
}

model Route {
  id          String        @id @default(uuid())
  name        String
  city        String
  description String?
  checkpoints Checkpoint[]
  sessions    GameSession[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Checkpoint {
  id        String              @id @default(uuid())
  route     Route               @relation(fields: [routeId], references: [id])
  routeId   String
  order     Int
  name      String
  latitude  Float
  longitude Float
  puzzle    Puzzle?
  attempts  CheckpointAttempt[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model Puzzle {
  id           String     @id @default(uuid())
  checkpoint   Checkpoint @relation(fields: [checkpointId], references: [id])
  checkpointId String     @unique
  question     String
  answer       String
  type         PuzzleType @default(TEXT)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model GameSession {
  id        String              @id @default(uuid())
  group     Group               @relation(fields: [groupId], references: [id])
  groupId   String
  route     Route               @relation(fields: [routeId], references: [id])
  routeId   String
  state     GameState           @default(CREATED)
  startTime DateTime?
  endTime   DateTime?
  score     Int                 @default(0)
  attempts  CheckpointAttempt[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model CheckpointAttempt {
  id           String      @id @default(uuid())
  session      GameSession @relation(fields: [sessionId], references: [id])
  sessionId    String
  checkpoint   Checkpoint  @relation(fields: [checkpointId], references: [id])
  checkpointId String
  answer       String
  correct      Boolean     @default(false)
  verified     Boolean     @default(false)
  photoUrl     String?
  attemptedAt  DateTime    @default(now())
}
